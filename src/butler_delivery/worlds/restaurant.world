    <!-- ==================== RECEPTION / HOME ==================== -->
    <model name="reception_counter">
      <static>true</static>
      <pose>-1.0 -3.8 0 0 0 0</pose>
      <link name="link">
        <pose>0 0 0.55 0 0 0</pose>
        <collision name="collision">
          <geometry><box><size>1.8 0.5 1.1</size></box></geometry>
        </collision>
