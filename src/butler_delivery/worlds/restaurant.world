        <visual name="visual">
          <geometry><box><size>1.0 0.6 0.05</size></box></geometry>
          <material><ambient>0.55 0.27 0.07 1</ambient><diffuse>0.55 0.27 0.07 1</diffuse></material>
        </visual>
      </link>
      <link name="leg1"><pose>-0.4 -0.2 0.175 0 0 0</pose>
        <collision name="c"><geometry><cylinder><radius>0.04</radius><length>0.35</length></cylinder></geometry></collision>
        <visual name="v"><geometry><cylinder><radius>0.04</radius><length>0.35</length></cylinder></geometry>
          <material><ambient>0.3 0.15 0.05 1</ambient><diffuse>0.3 0.15 0.05 1</diffuse></material></visual>
      </link>
      <link name="leg2"><pose>0.4 -0.2 0.175 0 0 0</pose>
        <collision name="c"><geometry><cylinder><radius>0.04</radius><length>0.35</length></cylinder></geometry></collision>
        <visual name="v"><geometry><cylinder><radius>0.04</radius><length>0.35</length></cylinder></geometry>
          <material><ambient>0.3 0.15 0.05 1</ambient><diffuse>0.3 0.15 0.05 1</diffuse></material></visual>
      </link>
      <link name="leg3"><pose>-0.4 0.2 0.175 0 0 0</pose>
        <collision name="c"><geometry><cylinder><radius>0.04</radius><length>0.35</length></cylinder></geometry></collision>
        <visual name="v"><geometry><cylinder><radius>0.04</radius><length>0.35</length></cylinder></geometry>
          <material><ambient>0.3 0.15 0.05 1</ambient><diffuse>0.3 0.15 0.05 1</diffuse></material></visual>
      </link>
      <link name="leg4"><pose>0.4 0.2 0.175 0 0 0</pose>
        <collision name="c"><geometry><cylinder><radius>0.04</radius><length>0.35</length></cylinder></geometry></collision>
        <visual name="v"><geometry><cylinder><radius>0.04</radius><length>0.35</length></cylinder></geometry>
          <material><ambient>0.3 0.15 0.05 1</ambient><diffuse>0.3 0.15 0.05 1</diffuse></material></visual>
      </link>
